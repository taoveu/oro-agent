# ─── Inference Provider ───────────────────────────────────────────────────────
# Choose your primary inference provider: chutes | openrouter
INFERENCE_PROVIDER=chutes

# Chutes API Key (https://chutes.ai)
CHUTES_API_KEY=your_chutes_api_key_here

# OpenRouter API Key (https://openrouter.ai) — alternative
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── LLM Model ────────────────────────────────────────────────────────────────
# Model to use for inference. Must be on the ORO allowlist.
# Options (Chutes): Qwen/Qwen3-32B-TEE, Qwen/Qwen3.5-397B-A17B-TEE,
#                   moonshotai/Kimi-K2.6-TEE, deepseek-ai/DeepSeek-V3.2-TEE
# Options (OpenRouter): qwen/qwen3-32b, qwen/qwen3.5-397b-a17b,
#                       moonshotai/kimi-k2.6, deepseek/deepseek-v3.2
SANDBOX_MODEL=Qwen/Qwen3-32B-TEE

# ─── Bittensor Wallet ────────────────────────────────────────────────────────
BITTENSOR_WALLET_NAME=default
BITTENSOR_WALLET_HOTKEY=default
BITTENSOR_NETWORK=finney
